{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "AllowedHosts": "*",
    "jwtSettings": {
        "Key": "ce4144d0518d19b1342d14d60e9f0a433c0f3dbc72957dcf5f9e6fba6e41abc2",
        "issuer": "IdentityService.API",
        "audience": "IdentityService.API.Client",
        "expiryInMinutes": 120
    },
    "ResetPasswordTokenSettings": {
        "Key": "d1f5e8c3a4b2c6e7f8a9b0c1d2e3f405060708090a0b0c0d0e0f1011121314151",
        "expiryInMinutes": 15,
        "issuer": "IdentityService.API",
